{
  "permissions": {
    "allow": [
      "Bash(xcodebuild:*)",
      "Bash(swift:*)",
      "Bash(xcrun:*)",
      "Bash(xcrun simctl:*)",
      "Bash(swift build:*)",
      "Bash(swiftlint:*)",
      "Bash(swiftformat:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(pod:*)",
      "Bash(open:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ]
  },
  "env": {
    "DEVELOPER_DIR": "/Applications/Xcode.app/Contents/Developer"
  }
}
